# Supabase — projeto: fcamarahorashub
# Configure na Vercel → Settings → Environment Variables (não commitar chaves reais)

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key-from-dashboard>

# Apenas no servidor (Vercel → Environment Variables). Nunca expor no client.
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Fonte de dados: planilha | supabase | mock
# Se omitido, usa planilha quando data/planilha/meta.json existir.
NEXT_PUBLIC_DATA_SOURCE=planilha

# URL pública do app (Open Graph / preview em Teams, WhatsApp, etc.)
NEXT_PUBLIC_SITE_URL=https://ftimesheethub.vercel.app

# Quando false e Supabase configurado, usa o banco. Enquanto true, prefere mock se DATA_SOURCE não for planilha.
NEXT_PUBLIC_USE_MOCK_DATA=true
